<?xml version="1.0"?>
<labwc_config>
  <core>
  </core>
  <theme>
    <name>Adwaita</name>
    <icon>Papirus-Dark</icon>
    <dropShadows>yes</dropShadows>
  </theme>
  <libinput>
    <device>
      <scrollFactor>1.2</scrollFactor>
    </device>
  </libinput>
  <!-- Define your workspaces here -->
  <desktops>
    <popupTime>1000</popupTime>
    <names>
      <name>1</name>
      <name>2</name>
      <name>3</name>
      <name>4</name>
    </names>
  </desktops>

  <keyboard>
    <default /> <!-- Keeps standard labwc hotkeys intact -->
    
    <!-- Switch Workspaces -->
    <keybind key="W-1"><action name="GoToDesktop" to="1" /></keybind>
    <keybind key="W-2"><action name="GoToDesktop" to="2" /></keybind>
    <keybind key="W-3"><action name="GoToDesktop" to="3" /></keybind>
    <keybind key="W-4"><action name="GoToDesktop" to="4" /></keybind>

    <!-- Send Active Window to Workspace -->
    <keybind key="W-S-1"><action name="SendToDesktop" to="1" /></keybind>
    <keybind key="W-S-2"><action name="SendToDesktop" to="2" /></keybind>
    <keybind key="W-S-3"><action name="SendToDesktop" to="3" /></keybind>
    <keybind key="W-S-4"><action name="SendToDesktop" to="4" /></keybind>
    <!-- Print Screen: Save full screen to ~/Pictures -->
    <keybind key="Print">
      <action name="Execute">
        <command>sh -c 'grim ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png'</command>
      </action>
    </keybind>

    <!-- Super + Shift + S: Select region and copy to clipboard -->
    <keybind key="W-S-s">
      <action name="Execute">
        <command>sh -c 'grim -g "$(slurp)" - | wl-copy'</command>
      </action>
    </keybind>

    <!-- Alt + Print Screen: Select region and save to ~/Pictures -->
    <keybind key="A-Print">
      <action name="Execute">
        <command>sh -c 'grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png'</command>
      </action>
    </keybind>
   </keyboard>

</labwc_config>
