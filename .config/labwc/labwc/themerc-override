# --- Labwc Zenburn Theme ---

# Borders (Green for active, dark grey for inactive)
border.width: 2
window.active.border.color: #7f9f7f
window.inactive.border.color: #2b2b2b

# Titlebar Backgrounds
window.active.title.bg: Solid
window.active.title.bg.color: #3f3f3f
window.inactive.title.bg: Solid
window.inactive.title.bg.color: #2b2b2b

# Titlebar Text
window.active.label.text.color: #dcdccc
window.inactive.label.text.color: #8f8f8f
window.label.text.justify: center

# Buttons
window.active.button.unpressed.image.color: #dcdccc
window.inactive.button.unpressed.image.color: #8f8f8f
window.button.hover.bg.color: #7f9f7f40

# Right-Click Menus
menu.items.bg.color: #3f3f3f
menu.items.text.color: #dcdccc
menu.items.active.bg.color: #7f9f7f
menu.items.active.text.color: #3f3f3f
menu.border.color: #7f9f7f

# On-Screen Display (Alt-Tab Window Switcher)
osd.bg.color: #3f3f3f
osd.border.color: #7f9f7f
osd.label.text.color: #dcdccc
osd.window-switcher.style-classic.item.active.border.color: #7f9f7f
osd.window-switcher.style-classic.item.active.bg.color: #7f9f7f
